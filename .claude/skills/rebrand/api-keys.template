# API Keys 配置模板
#
# 复制此文件为 .env 并填入你的 API keys
# cp .claude/skills/rebrand/api-keys.template .claude/skills/rebrand/.env
#
# 注意：不要提交 .env 文件到 Git！

# ================================
# OpenAI DALL-E 3（推荐）
# ================================
# 获取地址: https://platform.openai.com/api-keys
# 价格: $0.040-0.080 per image
# 格式: sk-proj-...
OPENAI_API_KEY=

# ================================
# Replicate（价格便宜）
# ================================
# 获取地址: https://replicate.com/account/api-tokens
# 价格: $0.00325-0.055 per image
# 格式: r8_...
REPLICATE_API_KEY=

# ================================
# Ideogram（最适合 Logo）
# ================================
# 获取地址: https://ideogram.ai/settings
# 价格: Free 25/day, Basic $8/month
# 格式: 字符串
IDEOGRAM_API_KEY=

# ================================
# 使用说明
# ================================
#
# 方法 1: 使用环境变量（推荐）
# ---------------------------------
# 在终端中运行:
#   source .claude/skills/rebrand/.env
#
# 然后生成:
#   node .claude/skills/rebrand/generate-branding.js "Gaming Bot" "#3B82F6" "openai"
#
# 方法 2: 直接在脚本中配置
# ---------------------------------
# 编辑 generate-branding.js 文件，在 CONFIG 对象中直接填入 API key
#
# 方法 3: 临时设置
# ---------------------------------
# 单次使用（macOS/Linux）:
#   OPENAI_API_KEY="sk-..." node .claude/skills/rebrand/generate-branding.js "Gaming Bot" "#3B82F6" "openai"
#
# 单次使用（Windows PowerShell）:
#   $env:OPENAI_API_KEY="sk-..."; node .claude/skills/rebrand/generate-branding.js "Gaming Bot" "#3B82F6" "openai"
